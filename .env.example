# StackBot Environment Configuration

# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Database Configuration (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://stackbot:stackbot_dev_pass@localhost:5432/stackbot
DB_PASSWORD=stackbot_dev_pass

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Encryption Secret for Private Keys (MUST BE EXACTLY 32 BYTES FOR AES-256)
# You can generate one via openssl rand -hex 16
ENCRYPTION_SECRET=your_32_byte_secret_key_here_abcd

# Stacks Network (testnet or mainnet)
STACKS_NETWORK=testnet

# Optional API Keys
BITFLOW_API_KEY=
ALEX_API_KEY=
VELAR_API_KEY=
FEE_WALLET_ADDRESS=
